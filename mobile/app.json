{
  "expo": {
    "name": "KIDS TRADE",
    "slug": "kids-trade",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "kidstrade",
    "userInterfaceStyle": "light",
    "icon": "./assets/app/icon.png",
    "splash": {
      "image": "./assets/app/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#f7f8f3"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kidstrade.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Takas için ürün fotoğrafı seçmek üzere galeriye erişim gerekir.",
        "NSCameraUsageDescription": "Ürün fotoğrafı çekmek için kamera erişimi gerekir."
      }
    },
    "android": {
      "package": "com.kidstrade.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/app/adaptive-icon.png",
        "backgroundColor": "#1f6b4f"
      },
      "permissions": ["CAMERA", "READ_MEDIA_IMAGES"]
    },
    "plugins": ["expo-router", "expo-font"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
