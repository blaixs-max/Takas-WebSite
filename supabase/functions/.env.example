# iyzico (önce SANDBOX ile test edin)
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com
IYZICO_API_KEY=sandbox-xxxxxxxxxxxxxxxx
IYZICO_SECRET_KEY=sandbox-xxxxxxxxxxxxxxxx
# Canlı: IYZICO_BASE_URL=https://api.iyzipay.com

# iyzico ödeme sonrası callback (bu fonksiyonun herkese açık URL'i)
IYZICO_CALLBACK_URL=https://<proje-ref>.supabase.co/functions/v1/iyzico-callback

# Ödeme sonrası kullanıcıyı uygulamaya geri getiren deep link
APP_RETURN_URL=kidstrade://payment-result

# Supabase (Edge Function ortamında SUPABASE_URL / SUPABASE_SERVICE_ROLE_KEY
# çoğu zaman otomatik gelir; gelmiyorsa secret olarak ekleyin)
SUPABASE_URL=https://<proje-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# SMS / OTP — NetGSM (yalnızca backend; başlık sağlayıcıda onaylı olmalı)
NETGSM_BASE_URL=https://api.netgsm.com.tr
NETGSM_USERCODE=850XXXXXXX
NETGSM_PASSWORD=********
NETGSM_HEADER=KIDSTRADE
# Supabase Dashboard → Auth → Hooks → Send SMS → secret (v1,whsec_...)
SEND_SMS_HOOK_SECRET=v1,whsec_xxxxxxxxxxxxxxxx
